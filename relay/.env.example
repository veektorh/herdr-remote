# Telegram bot
HERDR_TG_TOKEN=your-bot-token-here
HERDR_TG_CHAT_ID=your-chat-id

# Relay address (for clients connecting to this relay)
HERDR_RELAY=ws://127.0.0.1:8375

# Relay listener. Keep loopback when using Cloudflare Tunnel or Tailscale Serve.
HERDR_RELAY_BIND=127.0.0.1
HERDR_RELAY_PORT=8375

# Generate with: openssl rand -hex 32
HERDR_RELAY_TOKEN=replace-with-a-random-token

# Comma-separated browser origins when the PWA is hosted separately.
# Same-origin browser connections are allowed automatically.
HERDR_ALLOWED_ORIGINS=https://your-pwa.example

# Resource and abuse-control limits.
HERDR_MAX_CLIENTS=16
HERDR_MAX_PUSH_SUBSCRIPTIONS=64

# Optional canonical HTTPS URL used when generating pairing QR codes.
HERDR_PUBLIC_URL=https://herdr.example.com

# Runtime proxy status hint written by the installer: none, tailscale, named, or temp.
# Live health reporting verifies the active proxy instead of trusting this value.
HERDR_TUNNEL_MODE=tailscale

# Remote herdr instances via SSH (comma-separated)
HERDR_REMOTES=user@server1,user@server2
